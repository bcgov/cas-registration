{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>bcgov/renovate-config#2026.01',
  ],
  labels: [
    'dependencies',
    'run-all-ci',
  ],
  prConcurrentLimit: 5,
  dependencyDashboard: false,
  automerge: false,
  platformAutomerge: false,
  vulnerabilityAlerts: {
    enabled: true,
    schedule: [
      'at any time',
    ],
    labels: [
      'security',
      'dependencies',
    ],
  },
  constraints: {
    node: '24.x',
    yarn: '4.x',
    python: '3.12',
  },
  ignoreDeps: [],
  ignorePaths: [
    'helm/**',
    'requirements.txt',
    'data_import/**',
    'data_import_facilities/**',
    'disaster_recovery/**',
    'k6_results/**',
  ],
  lockFileMaintenance: {
    enabled: true,
    schedule: [
      'every weekend',
    ],
  },
  postUpgradeTasks: {
    commands: [
      'yarn dedupe',
    ],
    fileFilters: [
      'yarn.lock',
    ],
    executionMode: 'branch',
  },
  packageRules: [
    {
      description: 'Nx packages — must stay in sync',
      matchManagers: [
        'npm',
      ],
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      groupName: 'Nx (non-major)',
      groupSlug: 'nx-non-major',
      matchPackageNames: [
        '/^@nx//',
        '/^nx$/',
      ],
    },
    {
      description: 'Major updates: individual PRs, never grouped',
      matchUpdateTypes: [
        'major',
      ],
      groupName: null,
      addLabels: [
        'major-update',
      ],
    },
  ],
}
